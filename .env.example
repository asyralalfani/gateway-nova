# .env.example
# Copy file ini menjadi .env dan sesuaikan nilainya.
# JANGAN commit .env ke git.

# ===== Port =====
# Port non-default dipakai agar bisa coexist dengan app lain di server production.
# Ubah sesuai kebutuhan; semua referensi port di docker-compose & connection string
# memakai variabel ini.
APP_PORT=3100
POSTGRES_PORT=5433

# ===== Database =====
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
#
# - Saat run di dalam docker compose, app pakai host = "db" dan port = 5432
#   (port internal container, bukan POSTGRES_PORT).
# - Untuk dev lokal di host (pnpm prisma migrate dev, prisma studio),
#   pakai host = "localhost" dan port = POSTGRES_PORT.
POSTGRES_USER=homepage
POSTGRES_PASSWORD=homepage
POSTGRES_DB=homepage
DATABASE_URL="postgresql://homepage:homepage@localhost:5433/homepage?schema=public"

# ===== Autentikasi (opsional) =====
# Set true kalau mau enable login.
# Default false → semua orang yang akses URL bisa lihat & edit.
# Cocok kalau aplikasi di internal network yang sudah aman.
AUTH_ENABLED=false

# Wajib diisi kalau AUTH_ENABLED=true
# Generate dengan: openssl rand -base64 32
AUTH_SECRET=""

# URL public aplikasi (untuk callback auth). Sesuaikan kalau APP_PORT diubah.
NEXTAUTH_URL="http://localhost:3100"

# ===== Lain-lain =====
NODE_ENV=production
