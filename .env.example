# .env.example
# Copy this file to .env and adjust the values.
# DO NOT commit .env to git.

# ===== Ports =====
# Non-default ports so we can coexist with other apps on a production server.
# Change as needed; all port references in docker-compose & connection strings
# use these variables.
APP_PORT=3100
POSTGRES_PORT=5433

# ===== Database =====
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
#
# - Inside docker compose, the app uses host = "db" and port = 5432
#   (internal container port, not POSTGRES_PORT).
# - For local dev on the host (pnpm prisma migrate dev, prisma studio),
#   use host = "localhost" and port = POSTGRES_PORT.
POSTGRES_USER=homepage
POSTGRES_PASSWORD=homepage
POSTGRES_DB=homepage
DATABASE_URL="postgresql://homepage:homepage@localhost:5433/homepage?schema=public"

# ===== Authentication (optional) =====
# Set true to enable login.
# Default false → anyone who can reach the URL can view & edit.
# Suitable when the app sits on a trusted internal network.
AUTH_ENABLED=false

# Required when AUTH_ENABLED=true
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL of the app (used for auth callbacks). Adjust if APP_PORT changes.
NEXTAUTH_URL="http://localhost:3100"

# ===== Service status pinger (optional) =====
# When enabled, a sidecar container polls each tool URL on a schedule and
# stores up/down + response time on the Tool record. Leave PING_SECRET empty
# to disable (the pinger container will idle).
PING_ENABLED=true
# Generate with: openssl rand -hex 24
PING_SECRET=""
# How often (seconds) to run a full sweep over all tools.
PING_INTERVAL_SECONDS=300
# Per-URL timeout (milliseconds).
PING_TIMEOUT_MS=5000

# ===== Misc =====
NODE_ENV=production
