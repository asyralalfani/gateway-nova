// prisma/schema.prisma
// Database schema for Gateway Nova
// Learn Prisma: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Tool =====
// A single tool/URL entry shown on the homepage
model Tool {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  iconUrl     String?  // Path/URL to an icon, or an identifier from an icon library
  order       Int      @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  tags ToolTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?  // User ID (null when auth is disabled)

  @@index([categoryId])
  @@index([order])
}

// ===== Category =====
// Tool grouping (e.g. "DevOps", "Monitoring", "Docs")
model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  icon        String?
  color       String? // Hex color (e.g. "#3b82f6")
  order       Int     @default(0)

  tools Tool[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

// ===== Tag =====
// Free-form tags for filtering (e.g. "production", "internal", "monitoring")
model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  tools ToolTag[]
}

// Junction table: Tool <-> Tag (many-to-many)
model ToolTag {
  toolId String
  tagId  String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([toolId, tagId])
  @@index([tagId])
}

// ===== User =====
// Only used when AUTH_ENABLED=true
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN   // Can manage users and all data
  EDITOR  // Can CRUD tools & categories
  VIEWER  // Read-only
}
